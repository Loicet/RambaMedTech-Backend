generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  lang          String    @default("en")
  createdAt     DateTime  @default(now())

  conditions        UserCondition[]
  healthLogs        HealthLog[]
  emotionalCheckIns EmotionalCheckIn[]
  caregiverAccess   CaregiverAccess[]  @relation("CaregiverAccess")
  grantedAccess     CaregiverAccess[]  @relation("PatientAccess")
  memberships       CommunityMember[]
  contentProgress   ContentProgress[]
  emotionalCheckIns EmotionalCheckIn[]
  healthLogs        HealthLog[]
  notifications     Notification[]
  consent           PatientConsent?
  conditions        UserCondition[]
  pushSubscriptions PushSubscription[]
  auditLogs         AuditLog[]
}

model Condition {
  id          String               @id @default(uuid())
  name        String               @unique
  description String?
  content     EducationalContent[]
  logs        HealthLog[]
  users       UserCondition[]
}

model UserCondition {
  userId      String
  conditionId String
  assignedAt  DateTime  @default(now())
  condition   Condition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, conditionId])
}

model HealthLog {
  id          String    @id @default(uuid())
  userId      String
  conditionId String
  metric      String
  value       String
  unit        String?
  notes       String?
  loggedAt    DateTime  @default(now())
  condition   Condition @relation(fields: [conditionId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmotionalCheckIn {
  id        String       @id @default(uuid())
  userId    String
  emotion   EmotionLevel
  notes     String?
  checkedAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CaregiverAccess {
  id          String   @id @default(uuid())
  caregiverId String
  patientId   String
  grantedAt   DateTime @default(now())
  caregiver   User     @relation("CaregiverAccess", fields: [caregiverId], references: [id], onDelete: Cascade)
  patient     User     @relation("PatientAccess", fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([caregiverId, patientId])
}

model Community {
  id            String            @id @default(uuid())
  name          String            @unique
  description   String?
  conditionName String?           // links community to a condition
  createdAt     DateTime          @default(now())
  members       CommunityMember[]
  posts         CommunityPost[]
}

model CommunityMember {
  userId      String
  communityId String
  joinedAt    DateTime  @default(now())
  streak      Int       @default(0)
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, communityId])
}

model CommunityPost {
  id          String        @id @default(uuid())
  communityId String
  authorId    String
  content     String
  edited      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  community   Community     @relation(fields: [communityId], references: [id], onDelete: Cascade)
  likes       PostLike[]
  comments    PostComment[]
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model EducationalContent {
  id          String            @id @default(uuid())
  conditionId String
  title       String
  body        String
  createdAt   DateTime          @default(now())
  progress    ContentProgress[]
  condition   Condition         @relation(fields: [conditionId], references: [id], onDelete: Cascade)
}

model ContentProgress {
  userId    String
  contentId String
  readAt    DateTime           @default(now())
  content   EducationalContent @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, contentId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpRequest {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  name      String
  password  String
  role      Role     @default(USER)
  condition String?
  lang      String   @default("en")
  expiresAt DateTime
  createdAt DateTime @default(now())
  lang      String   @default("en")
}

model CareInvite {
  id             String   @id @default(uuid())
  code           String   @unique
  patientId      String
  caregiverEmail String
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  patient        User     @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model PatientConsent {
  patientId String  @id
  vitals    Boolean @default(true)
  mood      Boolean @default(true)
  symptoms  Boolean @default(true)
  insights  Boolean @default(true)
  reminders Boolean @default(true)
  patient   User    @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String   @id @default(uuid())
  userId    String
  title     String
  time      String
  type      String   @default("general")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id           String   @id @default(uuid())
  userId       String
  endpoint     String
  p256dh       String
  auth         String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model PasswordReset {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum Role {
  USER
  CAREGIVER
  ADMIN
}

enum EmotionLevel {
  GREAT
  GOOD
  OKAY
  LOW
  BAD
}
